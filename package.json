{
  "name": "agent-ledger",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:turbo": "next dev --turbo -H 0.0.0.0 -p 3000",
    "dev:clean": "node scripts/clean-next-dev.mjs && rm -rf node_modules/.cache && next dev -H 0.0.0.0 -p 3000",
    "prebuild": "npm run build:css-fallback",
    "build": "next build",
    "build:css-fallback": "tailwindcss -i ./app/globals.css -o ./public/ledger-tailwind.css --minify",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.96.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.47.10",
    "wagmi": "^2.19.5"
  },
  "overrides": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "^10.4.27",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
